{
  "name": "tree-tracker-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "bootstrap.js",
  "scripts": {
    "dev": "node --watch bootstrap.js",
    "start": "node bootstrap.js",
    "lint": "npm run db-lock:check",
    "db-lock:check": "node scripts/enforce-db-lock.js",
    "test": "node --test",
    "test:integration": "RUN_DB_TESTS=true node --test test/integration.db.test.js",
    "check": "npm run lint && npm test"
  },
  "dependencies": {
    "mysql2": "^3.14.5"
  }
}
